            .where('tradition', 'in', [user.tradition, 'all'])
            .get();

        qPool = [];
        snap.forEach(d => qPool.push({ id: d.id, ...d.data() }));

        if (qPool.length < 5) {
            // Fetch from Gemini if not enough questions
            await generateQuestionsWithGemini();
            return loadAndStartQuiz();
        }

        qPool = qPool.sort(() => 0.5 - Math.random()).slice(0, 25);
        qIdx = 0; score = 0;

