        document.getElementById('quiz-active').innerHTML = `
            <div class="reward-bar">
                <span class="reward-bar-text">ነጥቦችዎ</span>
                <span class="reward-pts">⭐ <span id="pts-display">${user.pts}</span></span>
            </div>
            <div class="quiz-card">
                <span class="quiz-badge" id="quiz-badge">${tradNames[user.tradition]}</span>
                <div id="timer-circle">20</div>
                <div id="qText"></div>
                <div id="opts-box"></div>
            </div>`;

        renderQ();

        // Config from Firebase
        try {
            const rewSnap = await db.collection('config').doc('rewards').get();
            if (rewSnap.exists) {
                winChance = rewSnap.data().winRate || 15;
                minToRoll = rewSnap.data().minScore || 90;
            }
        } catch(e) {}

    } catch(e) {
        console.log('Load error:', e);
        document.getElementById('quiz-active').innerHTML = '<p class="loading-text">ግንኙነት የለም! እንደገና ይሞክሩ።</p>';
    }
}

function renderQ() {
    const q = qPool[qIdx];
    document.getElementById('qText').innerText = q.text;
    const labels = ['ሀ','ለ','ሐ','መ'];
    let h = '';
    q.options.forEach((opt, i) => {
        const code = String.fromCharCode(65 + i);
        h += `<button class="opt-btn" onclick="checkAns('${code}')">
                <div class="opt-label">${labels[i]}</div>
                <span>${opt}</span>
              </button>`;
    });
    document.getElementById('opts-box').innerHTML = h;
    startTimer();
}

function startTimer() {
    tLeft = 20;
    clearInterval(timer);
    document.getElementById('timer-circle').innerText = tLeft;
    timer = setInterval(() => {
        tLeft--;
        const el = document.getElementById('timer-circle');
        if (el) el.innerText = tLeft;
        if (tLeft <= 5 && el) el.style.borderColor = 'orange';
        if (tLeft <= 0) { clearInterval(timer); checkAns('X'); }
    }, 1000);
}

function checkAns(a) {
    clearInterval(timer);
    const opts = document.querySelectorAll('.opt-btn');
    const correctCode = qPool[qIdx].correct;
    opts.forEach((btn, i) => {
        btn.onclick = null;
        const code = String.fromCharCode(65 + i);
        if (code === correctCode) btn.classList.add('correct');
        else if (code === a) btn.classList.add('wrong');
    });

    if (a === correctCode) {
        score++;
        user.pts += 10;
        document.getElementById('header-pts').textContent = user.pts;
        document.getElementById('pts-display').textContent = user.pts;
        document.getElementById('snd-correct').play().catch(() => {});
    } else {
        document.getElementById('snd-wrong').play().catch(() => {});
    }

    setTimeout(() => {
        qIdx++;
        if (qIdx < qPool.length) {
            renderQ();
            // Show popup ad every 5 questions
            if (qIdx % 5 === 0) showPopupAd();
        } else {
            showFinal();
        }
    }, 800);
}

async function showFinal() {
    document.getElementById('quiz-active').classList.add('hidden');
    document.getElementById('quiz-result').classList.remove('hidden');
    const pct = Math.round((score / qPool.length) * 100);
    document.getElementById('res-pct').innerText = pct + '%';
    document.getElementById('res-msg').innerText = pct >= 80
        ? 'እጅግ ጥሩ! ቃሉን ያውቃሉ 🎉'
        : pct >= 60
        ? 'ጥሩ ነው! ቀጥሉ 📖'
        : 'አዘኑ! ቀጥሉ ያስቡ 💪';

    localStorage.setItem('qal_user', JSON.stringify(user));

    try {
        await db.collection('results').add({
            name: user.name, phone: user.phone,
            tradition: user.tradition,
            score: pct, pts: user.pts,
            timestamp: firebase.firestore.FieldValue.serverTimestamp()
        });
    } catch(e) {}

    if (pct >= minToRoll) document.getElementById('roll-section').classList.remove('hidden');
}

function restartQuiz() {
    document.getElementById('quiz-result').classList.add('hidden');
    document.getElementById('quiz-start').classList.remove('hidden');
    const quizActive = document.getElementById('quiz-active');
    quizActive.classList.remove('hidden');
    quizActive.innerHTML = `
        <div class="reward-bar">
            <span class="reward-bar-text">ነጥቦችዎ</span>
            <span class="reward-pts">⭐ <span id="pts-display">${user.pts}</span></span>
        </div>
        <div class="quiz-card">
            <span class="quiz-badge" id="quiz-badge">${tradNames[user.tradition]}</span>
            <div id="timer-circle">20</div>
            <div id="qText"></div>
            <div id="opts-box"></div>
        </div>`;
    quizActive.classList.add('hidden');
    document.getElementById('quiz-start').classList.remove('hidden');
}

function startRoll() {
    const gift = document.getElementById('gift-box');
    gift.style.animation = 'shake 0.8s infinite';
    setTimeout(async () => {
        gift.style.animation = 'none';
        const win = (Math.random() * 100) < winChance;
        const rollSection = document.getElementById('roll-section');
        if (win) {
            rollSection.innerHTML = `<h3 style="color:var(--success)">እንኳን ደስ አሎት! 🎉</h3><p>የ 5 ብር ካርድ አግኝተዋል!</p>`;
            try {
                await db.collection('winners').add({
                    name: user.name, phone: user.phone,
                    prize: '5 ETB Card',
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
            } catch(e) {}
        } else {
            rollSection.innerHTML = `<p style="color:var(--danger)">አልደረሰዎትም 😔 — ደግሞ ይሞክሩ!</p>`;
        }
    }, 3000);
}

