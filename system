// GEMINI AI — QUESTION GENERATION
// ══════════════════════════════════════════════
async function generateQuestionsWithGemini() {
    const tradContext = {
        orthodox: 'Ethiopian Orthodox Tewahedo tradition, including fasting, saints (Synaxarium), liturgy (Qidasie), and Ethiopian church history',
        protestant: 'Protestant/Evangelical tradition, focusing on New Testament, salvation by faith, and evangelical theology',
        catholic: 'Catholic tradition including sacraments, catechism, and Ethiopian Catholic church',
        other: 'general Christian tradition and Bible knowledge'
    };

    const prompt = `Generate 50 Bible quiz questions in Amharic (Ethiopian language) for the ${tradContext[user.tradition]}.

Return ONLY valid JSON, no markdown, no explanation. Format:
[
  {
    "text": "question text in Amharic",
    "options": ["option A in Amharic", "option B in Amharic", "option C in Amharic", "option D in Amharic"],
    "correct": "A",
    "tradition": "${user.tradition}",
    "difficulty": "easy"
  }
]

Rules:
- All text must be in Amharic script
- correct field must be A, B, C, or D
- Mix easy, medium, hard questions
- Questions must be accurate Bible-based
- Include variety: Old Testament, New Testament, Ethiopian church specifics`;

    try {
        const res = await fetch(
            `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_KEY}`,
            {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{ parts: [{ text: prompt }] }],
                    generationConfig: { temperature: 0.7, maxOutputTokens: 4096 }
                })
            }
        );
        const data = await res.json();
        const raw = data.candidates[0].content.parts[0].text;
        const cleaned = raw.replace(/```json|```/g, '').trim();
        const questions = JSON.parse(cleaned);

        // Save to Firebase
        const batch = db.batch();
        questions.forEach(q => {
            const ref = db.collection('questions').doc();
            batch.set(ref, {
                ...q,
                generatedAt: firebase.firestore.FieldValue.serverTimestamp(),
                source: 'gemini'
            });
        });
        await batch.commit();
        console.log(`✅ ${questions.length} questions saved to Firebase`);
    } catch(e) {
        console.log('Gemini error:', e);
    }
}

