let currentTradFilter = 'all';

function renderBooks(filter = 'all', search = '') {
    const grid = document.getElementById('book-grid');
    const filtered = BOOKS.filter(b => {
        const tradMatch = filter === 'all' || b.trad === filter || b.trad === 'all';
        const searchMatch = !search || b.title.includes(search) || b.desc.includes(search);
        return tradMatch && searchMatch;
    });
    grid.innerHTML = filtered.map(b => `
        <div class="book-card" onclick="openBook(${b.id})">
            <div class="book-icon">${b.icon}</div>
            <div class="book-title">${b.title}</div>
            <div class="book-tag">${b.tag}</div>
        </div>
    `).join('');
}

function filterByTrad(el, trad) {
    document.querySelectorAll('.lib-chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    currentTradFilter = trad;
    renderBooks(trad, document.getElementById('lib-search-input').value);
}

function filterBooks() {
    renderBooks(currentTradFilter, document.getElementById('lib-search-input').value);
}

function openBook(id) {
    const book = BOOKS.find(b => b.id === id);
