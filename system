async function loadAds() {
    try {
        const snap = await db.collection('ads').doc('config').get();
        if (snap.exists) ads = snap.data().list || [];
    } catch(e) {}

    if (ads.length === 0) {
        ads = [
            { img:'', link:'#', audio:'', brand:'ቃለ ሕይወት መጻሕፍት', icon:'📚', desc:'የአማርኛ መንፈሳዊ መጻሕፍት ቤት', tag:'አዲስ አበባ' },
            { img:'', link:'#', audio:'', brand:'ላሊበላ ጉዞ ኤጀንሲ', icon:'✈️', desc:'ወደ ላሊበላ ቅዱስ ጉዞ ያቅዱ', tag:'ከ 3,500 ብር' },
        ];
    }

    updateBanner();
    setInterval(updateBanner, 7000);
}

function updateBanner() {
    if (!ads.length) return;
    const ad = ads[currentAdIdx % ads.length];
    currentAdIdx++;

    const box = document.getElementById('ad-banner-box');
    if (ad.img) {
        box.innerHTML = `<img src="${ad.img}" class="ad-banner-img" onclick="window.open('${ad.link || '#'}','_blank')">`;
    } else {
        box.innerHTML = `
            <div style="display:flex; align-items:center; gap:10px; animation: fadeIn 0.6s;">
                <div style="font-size:30px;">${ad.icon || '📢'}</div>
                <div>
                    <div style="font-size:13px; font-weight:bold; color:var(--primary);">${ad.brand}</div>
                    <div style="font-size:11px; color:var(--subtext);">${ad.desc}</div>
                </div>
                <div style="margin-left:auto; font-size:11px; font-weight:bold; color:var(--accent);">${ad.tag || ''}</div>
            </div>`;
    }

    if (ad.audio) {
        const audio = document.getElementById('ad-audio');
        audio.src = ad.audio;
        audio.play().catch(() => {});
    }
}

// Popup ad system
function showPopupAd() {
    if (!ads.length) return;
    const ad = ads[Math.floor(Math.random() * ads.length)];
    currentPopupAd = ad;

    document.getElementById('popup-icon').textContent = ad.icon || '📢';
    document.getElementById('popup-brand').textContent = ad.brand || 'ማስታወቂያ';
    document.getElementById('popup-tag').textContent = ad.tag || '';
    document.getElementById('popup-desc').textContent = ad.desc || '';
    document.getElementById('popup-overlay').classList.remove('hidden');

    // Countdown
    let count = 5;
    const skipBtn = document.getElementById('popup-skip');
    const countEl = document.getElementById('popup-countdown');
    skipBtn.disabled = true;
    skipBtn.style.opacity = '0.5';
    countEl.textContent = count;

    clearInterval(popupTimer);
    popupTimer = setInterval(() => {
        count--;
        countEl.textContent = count;
        if (count <= 0) {
            clearInterval(popupTimer);
            skipBtn.disabled = false;
            skipBtn.style.opacity = '1';
            skipBtn.textContent = 'ዝለሉ ✕';
        }
    }, 1000);
}

function popupClick() {
    if (currentPopupAd?.link) window.open(currentPopupAd.link, '_blank');
    closePopup();
}

function closePopup() {
    document.getElementById('popup-overlay').classList.add('hidden');
    clearInterval(popupTimer);
}

