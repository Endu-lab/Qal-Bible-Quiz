async function sendChat() {
    const input = document.getElementById('chat-input');
    const val = input.value.trim();
    if (!val) return;

    const window_ = document.getElementById('chat-window');
    const userMsg = document.createElement('div');
    userMsg.className = 'msg msg-user';
    userMsg.textContent = val;
    window_.appendChild(userMsg);
    input.value = '';
    window_.scrollTop = window_.scrollHeight;

    // Thinking indicator
    const thinking = document.createElement('div');
    thinking.className = 'msg msg-ai';
    thinking.textContent = '...በማሰብ ላይ 🤔';
    window_.appendChild(thinking);
    window_.scrollTop = window_.scrollHeight;

    try {
        const tradContext = tradNames[user.tradition] || 'ክርስቲያን';
        const prompt = `You are Qetero, an Ethiopian Bible assistant for the Qal app. 
The user follows the ${tradContext} tradition.
Answer ONLY Bible-based questions. 
Always respond in Amharic (Ethiopian script).
Be respectful, accurate, and spiritually grounded.
Keep answers concise but helpful.

User question: ${val}`;

        const res = await fetch(
            `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_KEY}`,
            {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{ parts: [{ text: prompt }] }],
                    generationConfig: { temperature: 0.5, maxOutputTokens: 512 }
                })
            }
        );
        const data = await res.json();
        const reply = data.candidates[0].content.parts[0].text;
        thinking.textContent = reply;
    } catch(e) {
        thinking.textContent = 'ይቅርታ! ምላሽ ለማምጣት አልተቻለም። እንደገና ይሞክሩ። 🙏';
    }
    window_.scrollTop = window_.scrollHeight;
}

