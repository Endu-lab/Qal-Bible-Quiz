<!DOCTYPE html>
<html lang="am">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qal Christian Society</title>

    <!-- 1. FIREBASE CORE TOOLS (The SDK) -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>

    <style>
        /* Basic styling to make sure we can see the content */
        body { font-family: sans-serif; margin: 0; padding: 20px; background: #f4f4f4; }
        .screen { display: none; }
        .screen.active { display: block; }
        .post-card { background: white; padding: 15px; margin-bottom: 10px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .nav-btn { cursor: pointer; padding: 10px; background: #007bff; color: white; display: inline-block; margin-right: 5px; border-radius: 5px; }
        .loading-text { color: #666; font-style: italic; }
    </style>
</head>
<body>

    <div id="app-header">
        <h1>ቃለ (Qal)</h1>
        <div class="nav-btn" onclick="goTo('posts')">ጽሑፎች (Posts)</div>
        <div class="nav-btn" onclick="goTo('library')">ቤተ-መጻሕፍት (Library)</div>
    </div>

    <hr>

    <!-- POSTS SCREEN -->
    <div id="scr-posts" class="screen active">
        <h2>የማኅበረሰቡ ጽሑፎች</h2>
        <div id="posts-list">ጽሑፎች በመጫን ላይ...</div>
    </div>

    <!-- LIBRARY SCREEN -->
    <div id="scr-library" class="screen">
        <h2>መጻሕፍት</h2>
        <div id="book-grid">መጻሕፍት በመጫን ላይ...</div>
    </div>

    <script>
        // 2. FIREBASE CONFIGURATION
        const firebaseConfig = {
            apiKey: "AIzaSyDfGIbFp3JNFVUv3aoghgLoAcj_9vFlf9E",
            authDomain: "qal-christian-society.firebaseapp.com",
            projectId: "qal-christian-society",
            storageBucket: "qal-christian-society.firebasestorage.app",
            messagingSenderId: "1077878834449",
            appId: "1:1077878834449:web:83482024afd7c2cd9938b0",
            measurementId: "G-JSV8XHE65K"
        };

        // Initialize Firebase
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }
        const db = firebase.firestore();

        // 3. NAVIGATION LOGIC
        function goTo(screenId) {
            // Hide all screens
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            // Show the selected one
            const target = document.getElementById('scr-' + screenId);
            if(target) target.classList.add('active');

            // Load data when screen opens
            if (screenId === 'posts') loadPosts();
            if (screenId === 'library') loadLibrary();
        }

        // 4. LOAD POSTS FROM FIREBASE
        function loadPosts() {
            const postsList = document.getElementById('posts-list');
            
            // Try to get data from the "posts" collection
            db.collection("posts").get()
            .then((querySnapshot) => {
                postsList.innerHTML = ""; 
                if (querySnapshot.empty) {
                    postsList.innerHTML = '<div>ምንም ጽሑፍ አልተገኘም:: እባክዎ በFirebase Console ውስጥ "posts" የሚል Collection መኖሩን ያረጋግጡ::</div>';
                    return;
                }
                querySnapshot.forEach((doc) => {
                    const post = doc.data();
                    postsList.innerHTML += `
                        <div class="post-card">
                            <h3>${post.title || "ያልተሰየመ"}</h3>
                            <p>${post.content || ""}</p>
                            <small>በ ${post.author || "ያልታወቀ"} ተጻፈ</small>
                        </div>`;
                });
            })
            .catch((error) => {
                console.error("Error:", error);
                postsList.innerHTML = "Error: " + error.message;
            });
        }

        // 5. LOAD LIBRARY FROM FIREBASE
        function loadLibrary() {
            const bookGrid = document.getElementById('book-grid');
            db.collection("library").get()
            .then((querySnapshot) => {
                bookGrid.innerHTML = "";
                querySnapshot.forEach((doc) => {
                    const book = doc.data();
                    bookGrid.innerHTML += `
                        <div class="post-card">
                            <strong>${book.title}</strong><br>
                            <button onclick="window.open('${book.url}', '_blank')">አንብብ (Read)</button>
                        </div>`;
                });
            });
        }

        // 6. RUN IMMEDIATELY ON LOAD
        // This ensures the posts show up as soon as the website opens
        window.onload = function() {
            loadPosts();
        };

    </script>
</body>
</html>
